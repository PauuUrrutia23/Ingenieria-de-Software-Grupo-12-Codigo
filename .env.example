APP_NAME=Ingecon
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Santiago
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------
# Base de datos — PostgreSQL 16
# Ajusta DB_USERNAME y DB_PASSWORD segun tu instalacion local.
# -----------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ingecon_db
DB_USERNAME=postgres
DB_PASSWORD=

# -----------------------------------------------------------------------
# Sesion / Cache / Cola
# -----------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file

QUEUE_CONNECTION=sync

# -----------------------------------------------------------------------
# Correo — log en desarrollo / smtp (Resend) en produccion
# -----------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@ingecon.cl"
MAIL_FROM_NAME="${APP_NAME}"

RESEND_KEY=

FILESYSTEM_DISK=local
BCRYPT_ROUNDS=12

VITE_APP_NAME="${APP_NAME}"
