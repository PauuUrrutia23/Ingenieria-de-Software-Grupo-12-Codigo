app/
├── Http/
│   ├── Controllers/
│   │   └── AuthController.php
│   └── Middleware/
│       └── AdminAuth.php
├── Mail/
│   └── CuentaBloqueadaMail.php
├── Jobs/
│   └── EnviarEmailBloqueoJob.php
└── Models/
    ├── Administrador.php   (ya definido en 02_modelos_eloquent.md)
    └── Sesion.php          (ya definido en 02_modelos_eloquent.md)

resources/views/
└── auth/
