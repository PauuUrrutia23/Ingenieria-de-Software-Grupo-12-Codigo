# ─────────────────────────────────────────────
# Configuracion de la aplicacion
# ─────────────────────────────────────────────
APP_NAME="Ingecon"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ─────────────────────────────────────────────
# Base de datos — PostgreSQL 16
# ─────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ingecon_db
DB_USERNAME=ingecon_user
DB_PASSWORD=secret_password

# ─────────────────────────────────────────────
# Hashing — Argon2id (config/hashing.php)
# ─────────────────────────────────────────────
HASH_DRIVER=argon2id

# ─────────────────────────────────────────────
# Email — Resend SMTP (notificacion de bloqueo RF34)
# ─────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=re_TU_API_KEY_DE_RESEND
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@ingecon.cl
MAIL_FROM_NAME="Ingecon Sistema"

# ─────────────────────────────────────────────
# Sesion
# ─────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_COOKIE=ingecon_session
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ─────────────────────────────────────────────
# Cola de trabajos (Jobs: EnviarEmailBloqueoJob)
# ─────────────────────────────────────────────
QUEUE_CONNECTION=sync

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────
# Cache y Broadcasting
# ─────────────────────────────────────────────
BROADCAST_CONNECTION=log
CACHE_STORE=database

# ─────────────────────────────────────────────
# Almacenamiento de archivos
# ─────────────────────────────────────────────
FILESYSTEM_DISK=local
